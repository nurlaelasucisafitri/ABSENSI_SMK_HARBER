# ============================================================
# Konfigurasi Environment - Backend Absensi Sekolah
# Salin file ini ke .env dan sesuaikan dengan environment Anda
# ============================================================

# --- Server ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- Database MySQL ---
DB_HOST=localhost
